<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SoundBoard.UI.ViewModels"
             xmlns:controls="using:SoundBoard.UI.Controls"
             x:Class="SoundBoard.UI.Views.ShortcutsView"
             x:DataType="vm:ShortcutsViewModel">

    <UserControl.Styles>
        <Style Selector="ItemsControl > ContentPresenter > Button">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
            <Setter Property="RenderTransform" Value="scale(1)" />
        </Style>
        <Style Selector="ItemsControl > ContentPresenter > Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.04)" />
        </Style>

        <!-- Fluent's Button template forces BorderBrush to a theme color on
             :pointerover and :pressed, which would hide the playing/paused
             outline. Re-bind to the Button's own BorderBrush (which is bound
             to OutlineBrush on the VM) so the state colour shows through. -->
        <Style Selector="ItemsControl > ContentPresenter > Button:pointerover /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{Binding $parent[Button].BorderBrush}" />
        </Style>
        <Style Selector="ItemsControl > ContentPresenter > Button:pressed /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{Binding $parent[Button].BorderBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Row 0: Page Tabs (scrollable) + Page Management actions.
             The TabStrip is wrapped in a horizontal ScrollViewer so a long
             list of pages clips at the column boundary instead of running
             under the action buttons, and a scrollbar appears when the tabs
             don't fit. The "+" (Add Page) and "Pop Out" buttons share the
             right-side column so they stay anchored and visible regardless
             of how many tabs are present, scrolled, or selected.
             Mouse-wheel-to-horizontal-scroll is wired in code-behind. -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
            <ScrollViewer Grid.Column="0"
                          x:Name="PageTabsScroller"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          PointerWheelChanged="OnPageTabsWheel">
                <TabStrip ItemsSource="{Binding Pages}" SelectedItem="{Binding SelectedPage}">
                    <TabStrip.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Padding="10,5"
                                       DoubleTapped="OnPageTabDoubleTapped">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Rename Page..." Click="OnRenamePageClicked" />
                                        <MenuItem Header="Delete Page" Click="OnDeletePageClicked" />
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </ScrollViewer>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" Margin="10,0,0,0">
                <!-- Add Page Button -->
                <Button Content="+" FontSize="18" FontWeight="Bold" Padding="10,3"
                        Background="{DynamicResource SuccessBackground}" Foreground="{DynamicResource SuccessForeground}" CornerRadius="6"
                        ToolTip.Tip="Add new page" Command="{Binding AddPageCommand}" />
                <Button Content="Pop Out 🗗" Command="{Binding PopOutCommand}" Classes="primary" />
            </StackPanel>
        </Grid>

        <!-- Row 1: Dynamic Grid of Shortcut Buttons -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ShortcutItems"
                          ItemsSource="{Binding CurrentButtons}"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="120" ItemHeight="120" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding ClickCommand}" 
                                BorderBrush="{Binding OutlineBrush}" 
                                BorderThickness="3" 
                                CornerRadius="8" 
                                Margin="10" 
                                Background="{DynamicResource PanelBackground3}" 
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                DragDrop.AllowDrop="True"
                                DragDrop.DragOver="OnButtonDragOver"
                                DragDrop.Drop="OnButtonDrop"
                                Tag="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="✏ Rename..." Click="OnRenameButtonClicked" />
                                    <MenuItem Header="🎨 Set icon..." Click="OnSetButtonIconClicked" />
                                    <MenuItem Header="🎛 FX Chain..." Click="OnConfigureShortcutSamplersClicked" />
                                    <MenuItem Header="🎚 Bus override..." Click="OnSetButtonBusOverrideClicked"
                                              IsVisible="{Binding IsTrackTarget}" />
                                    <Separator />
                                    <MenuItem Header="🗑 Remove" Click="OnRemoveButtonClicked" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Grid RowDefinitions="*, Auto">
                                <controls:RpgIcon Grid.Row="0" IconName="{Binding EffectiveIcon}"
                                                  FontSize="36"
                                                  Foreground="{DynamicResource PrimaryAccent}"
                                                  IsVisible="{Binding HasIcon}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1" Text="{Binding Label}"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           FontWeight="Bold" Foreground="{DynamicResource OnPrimaryAccent}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
